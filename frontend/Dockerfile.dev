# Dev — Vite hot reload. Build context: fast-svelte root (npm workspaces).

FROM node:22-alpine

WORKDIR /app

COPY package.json ./
COPY frontend/package.json ./frontend/

RUN npm install

COPY frontend ./frontend

WORKDIR /app

EXPOSE 5173

CMD ["npm", "run", "dev", "-w", "frontend", "--", "--host", "0.0.0.0", "--port", "5173"]
