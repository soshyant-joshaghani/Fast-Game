# fast-game — copy to .env and fill in real values.
# URLs, CORS, domains, and PROJECT_NAME live in compose.*.yml — not here.

SECRET_KEY=change-me
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=Admin@1234

# Frontend (Vite) — Colyseus WebSocket URL for dev
PUBLIC_GAME_SERVER_URL=ws://game.localhost

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Host / IDE — published ports from compose.dev.yml
POSTGRES_SERVER=localhost
POSTGRES_PORT=15432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=PG@1234

SENTRY_DSN=
